{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, s-maxage=0, must-revalidate" }
      ]
    }
  ],
  "redirects": [
    { "source": "/index.html", "destination": "/", "permanent": true },
    { "source": "/v2.html", "destination": "/", "permanent": true },
    { "source": "/v4.html", "destination": "/", "permanent": true }
  ],
  "rewrites": [
    {
      "source": "/",
      "has": [
        { "type": "query", "key": "pc", "value": "0" }
      ],
      "destination": "/original-2026-04-18-index"
    },
    {
      "source": "/",
      "has": [
        { "type": "query", "key": "pc", "value": "2" }
      ],
      "destination": "/lp"
    },
    {
      "source": "/",
      "has": [
        { "type": "query", "key": "pc", "value": "5" }
      ],
      "destination": "/v3"
    },
    {
      "source": "/",
      "has": [
        { "type": "query", "key": "pc", "value": "6" }
      ],
      "destination": "/v6"
    },
    {
      "source": "/",
      "has": [
        { "type": "query", "key": "pc", "value": "7" }
      ],
      "destination": "/v7"
    },
    {
      "source": "/",
      "destination": "/v5"
    }
  ]
}
